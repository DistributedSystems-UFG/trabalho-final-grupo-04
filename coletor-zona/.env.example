# Exemplo de configuração do Coletor de Zona.
# Suba um par por zona: um PRIMARIO e uma REPLICA.

# --- comum ---
ZONA_ID=centro
MQTT_BROKER_URL=tcp://localhost:1883

# --- exemplo PRIMARIO ---
PAPEL_INICIAL=PRIMARIO
GRPC_PORT=50051
REPLICA_ADDR=localhost:60051

# --- exemplo REPLICA (em outro processo) ---
# PAPEL_INICIAL=REPLICA
# GRPC_PORT=50061
# REPLICACAO_PORT=60051
